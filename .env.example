PORT=3000

# OpenAI is called only from server.js.
# Leave these empty to use deterministic demo fallback recommendations.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Supabase logging is optional for the first demo.
# Use server-side keys only. Never expose these in public/app.js.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RECOMMENDATION_TABLE=recommendation_logs
SUPABASE_SAVINGS_TABLE=savings_logs

