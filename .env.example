PORT=3000
HOST=0.0.0.0
SESSION_TTL_DAYS=7
SESSION_COOKIE_SECURE=false

# Optional admin bootstrap. When both are set, the server creates or updates
# this account as role=admin and status=active on startup.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Admin

# Local auth and app data are stored server-side.
# Leave empty to use ./data/app.db.json. Never commit files in ./data.
LOCAL_DB_PATH=

# Groq is called only from server.js.
# Leave these empty to use deterministic demo fallback recommendations.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_MAX_TOKENS=2200

# Supabase can be the primary database when URL and service role key are set.
# Use server-side keys only. Never expose these in public/app.js.
SUPABASE_DB_ENABLED=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public
SUPABASE_MAX_ROWS=5000

# These table names are used only when SUPABASE_DB_ENABLED=false and you still
# want local DB plus Supabase recommendation logging.
SUPABASE_RECOMMENDATION_TABLE=recommendation_logs
SUPABASE_SAVINGS_TABLE=savings_logs
